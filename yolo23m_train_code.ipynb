import os
import torch
from ultralytics import YOLO

def main():
    # 1. GPU(CUDA) 사용 가능 여부 확인 및 할당
    device = '0' if torch.cuda.is_available() else 'cpu'
    print(f"====================================")
    print(f" 현재 사용 장치: {device}")
    print(f"====================================")

    # 2. 보유하고 계신 YOLO26m 가중치 파일 불러오기
    model = YOLO('yolo26m.pt')

    # 3. 모델 학습 시작
    print("YOLO26m 모델 학습을 시작합니다. 소규모 데이터셋 최적화 세팅이 적용됩니다...\n")
    
    results = model.train(
        # [📂 기본 경로 및 주기 설정]
        data='dataset.yaml',       # 라벨 정보가 담긴 yaml 파일명
        epochs=100,                # 전체 데이터셋 반복 학습 횟수
        imgsz=640,                 # 이미지 입력 크기
        batch=16,                  # 배치 크기 (메모리 부족 시 8로 하향)
        device=device,             # 사용할 연산 장치
        name='train_run2',         # 학습 결과가 저장될 폴더명

        # [⚙️ 과적합 방지 및 최적화]
        patience=30,               # 30에포크 동안 성능 개선 없으면 조기 종료
        cos_lr=True,               # 학습 속도를 부드럽게 감소시켜 안정적 수렴
        
        # [🎨 YOLO26 규격에 맞는 올바른 데이터 증강 파이프라인]
        degrees=15.0,              # ±15도 범위 내 무작위 회전 (웹캠 기울어짐 대비)
        fliplr=0.5,                # 50% 확률로 좌우 반전 (데이터 부풀리기 효과)
        mosaic=0.5,                # 소규모 데이터셋 권장 모자이크 비율 설정
        scale=0.5,                 # ±50% 범위 확대/축소 (웹캠과의 거리 변화 대응)
        translate=0.1,             # 상하좌우 10% 범위 위치 이동 (화면 구석 배치 대응)
        perspective=0.0005         # 3D 원근감 왜곡 적용 (측면 카메라 각도 대응)
    )

    print("\n====================================")
    print(" 모든 에포크가 수행되어 YOLO26m 모델 학습이 완료되었습니다.")
    print(" 결과물은 'runs/detect/train_run2/' 폴더에서 확인 가능합니다.")
    print("====================================")

if __name__ == '__main__':
    main()
